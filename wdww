-- EXACT original error check
local function originalErrorCheck()
    local _, msg = _pcall(function() game() end)
    if not _string_find(msg, "attempt to call a Instance value") then
        antitamperDetect("game() error message spoofed")
    end
end

-- EXACT original fingerprint functions
local function deepFingerprint(f)
    if _type(f) ~= "function" then return nil end
    local ok, info = _pcall(dbg_getinfo, f)
    if not ok or not info then return nil end
    local parts = {
        info.what or "",
        info.source or "",
        _tostring(info.nups or ""),
        _tostring(info.numparams or ""),
        _tostring(info.isvararg or ""),
    }
    for i = 1, (info.nups or 0) do
        local ok2, v = _pcall(dbg_getupvalue, f, i)
        _insert(parts, ok2 and _tostring(v) or "?")
    end
    if dbg_getconstants then
        local ok3, consts = _pcall(dbg_getconstants, f)
        if ok3 and consts then
            for _, c in _ipairs(consts) do _insert(parts, _tostring(c)) end
        end
    end
    return _concat(parts, "|")
end

local function fnAddress(f)
    if _type(f) ~= "function" then return nil end
    return _tostring(f)
end

local function snapshotUpvalues(f)
    if _type(f) ~= "function" then return {} end
    local ok, info = _pcall(dbg_getinfo, f)
    if not ok or not info then return {} end
    local snap = {}
    for i = 1, (info.nups or 0) do
        local ok2, v = _pcall(dbg_getupvalue, f, i)
        snap[i] = ok2 and _tostring(v) or "?"
    end
    return snap
end

local function checkUpvalues(f, snap)
    if _type(f) ~= "function" then return false end
    local ok, info = _pcall(dbg_getinfo, f)
    if not ok or not info then return false end
    for i = 1, (info.nups or 0) do
        local ok2, v = _pcall(dbg_getupvalue, f, i)
        local cur = ok2 and _tostring(v) or "?"
        if cur ~= (snap[i] or "?") then return false end
    end
    return true
end

function Protection:snapshot(name, fn)
    if fn == nil then return end
    self.baseline[name] = {
        fp = deepFingerprint(fn),
        addr = fnAddress(fn),
        uvs = snapshotUpvalues(fn),
    }
end

-- EXACT original snapshots
local function takeSnapshots()
    Protection:snapshot("request", raw_request)
    Protection:snapshot("isfunctionhooked", raw_isfunctionhooked)
    Protection:snapshot("ishooked", raw_ishooked)
    Protection:snapshot("hookfunction", raw_hookfunction)
    Protection:snapshot("dbg_getinfo", dbg_info)
    Protection:snapshot("checkcaller", raw_checkcaller)
    Protection:snapshot("task_wait", task.wait)
    Protection:snapshot("task_spawn", task.spawn)
    Protection:snapshot("task_delay", task.delay)
end

-- EXACT original runtime monitoring
local function runtimeMonitoring()
    while Protection.protection_ON do
        _task_wait(0.5)

        _pcall(function()
            local fnMap = {
                request = raw_request,
                isfunctionhooked = raw_isfunctionhooked,
                ishooked = raw_ishooked,
                hookfunction = raw_hookfunction,
                dbg_getinfo = dbg_info,
                checkcaller = raw_checkcaller,
            }
            for name, fn in _pairs(fnMap) do
                if fn ~= nil and Protection.baseline[name] then
                    local b = Protection.baseline[name]
                    if raw_isfunctionhooked and raw_isfunctionhooked(fn) then
                        antitamperDetect(name .. " is hooked (runtime)")
                    end
                    if deepFingerprint(fn) ~= b.fp then
                        antitamperDetect(name .. " fingerprint changed")
                    end
                    if fnAddress(fn) ~= b.addr then
                        antitamperDetect(name .. " address changed")
                    end
                    if not checkUpvalues(fn, b.uvs) then
                        antitamperDetect(name .. " upvalues tampered")
                    end
                end
            end
        end)
    end
end

-- Main start function
function Protection:start()
    self.protection_ON = true
    
    self.connections.main = _task_spawn(function()
        initHeartbeat()
        
        -- EXACT original check sequence
        if self.anti_httpspy then
            originalHTTPSpyCheck()
        end
        
        if self.anti_tamper then
            originalTaskChecks()
            originalEnvCheck()
            originalJSONCheck()
            originalErrorCheck()
            takeSnapshots()
        end
        
        -- EXACT original runtime loop
        runtimeMonitoring()
    end)
end

function Protection:stop()
    self.protection_ON = false
    self.anti_httpspy = false
    self.anti_tamper = false
    for _, conn in pairs(self.connections) do
        if typeof(conn) == "thread" then
            task.cancel(conn)
        end
    end
    self.connections = {}
end

return Protection
