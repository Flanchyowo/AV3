-- EXACT original functions
local function encode(s)
    local t = {}
    for i = 1, #s do _insert(t, _string_byte(s, i)) end
    return t
end

local function decode(t)
    local chars = {}
    for _, b in _ipairs(t) do _insert(chars, _string_char(b)) end
    return _concat(chars)
end

local KICKED = false
local function kick(reason)
    if KICKED then return end
    KICKED = true
    local encoded = encode(reason or "integrity violation")
    _task_spawn(function()
        for _ = 1, 5 do
            _pcall(function() LocalPlayer:Kick(decode(encoded)) end)
            _task_wait(0.05)
        end
    end)
end

local function shout()
    _pcall(_error, "\n\n[ANTICHEAT] " .. DETECT_MSG .. "\n")
    _pcall(_error, "[ANTICHEAT] " .. DETECT_MSG)
    _pcall(_warn, "[ANTICHEAT] " .. DETECT_MSG)
    _pcall(function()
        print("=" .. _string_rep("=", 40))
        print("!! " .. DETECT_MSG)
        print("=" .. _string_rep("=", 40))
    end)
end

-- Modular detection (replaces detectAndKick)
local function httpspyDetect(reason)
    if Protection.anti_httpspy then
        shout()
        kick(reason or DETECT_MSG)
        on_httpspy_detect:Fire(reason)
    end
end

local function antitamperDetect(reason)
    if Protection.anti_tamper then
        shout()
        kick(reason or DETECT_MSG)
        on_antitamper_detect:Fire(reason)
    end
end

-- EXACT original task check functions
local function _twcheck(what)
    if what ~= "C" then antitamperDetect("task.wait hooked") end
end

local function _tscheck(what)
    if what ~= "C" then antitamperDetect("task.spawn hooked") end
end

local function _tdcheck(what)
    if what ~= "C" then antitamperDetect("task.delay hooked") end
end

-- EXACT original task checks
local function originalTaskChecks()
    local _twok, _twinfo = _pcall(dbg_getinfo, task.wait)
    _twcheck(_twok and _twinfo and _twinfo.what or "hooked")

    local _tsok, _tsinfo = _pcall(dbg_getinfo, task.spawn)
    _tscheck(_tsok and _tsinfo and _tsinfo.what or "hooked")

    local _tdok, _tdinfo = _pcall(dbg_getinfo, task.delay)
    _tdcheck(_tdok and _tdinfo and _tdinfo.what or "hooked")
end

-- EXACT original heartbeat
local function initHeartbeat()
    local _heartbeatCount = 0
    local _heartbeatConn = RunService.Heartbeat:Connect(function()
        _heartbeatCount += 1
    end)
    repeat _task_wait() until _heartbeatCount >= 2
    _heartbeatConn:Disconnect()
end



-- EXACT original env check
local function originalEnvCheck()
    local envBad = false

    if not _getmetatable or not _setmetatable or not _type or not _select then envBad = true end
    if not _pcall or not debug or not _rawget or not _rawset then envBad = true end
    if not _pcall(_rawset, {}, " ", " ") then envBad = true end
    if _getmetatable(require) or _getmetatable(print) or _getmetatable(_error) then envBad = true end

    do
        local _trap = _setmetatable({}, {__index = function(self, ...) while true do end end})
        local _ok, _mt = _pcall(_getmetatable, _trap)
        if not _ok or _type(_rawget(_mt, "__index")) ~= "function" then envBad = true end
    end

    if ({dbg_info(print, 'a')})[1] ~= 0 then envBad = true end
    if ({dbg_info(tostring, 'a')})[1] ~= 0 then envBad = true end
    if ({dbg_info(print, 'a')})[2] ~= true then envBad = true end

    if not raw_getfenv then envBad = true end
    if _select(1, _pcall(raw_getfenv, 69)) == true then envBad = true end

    do
        local ok, dbginfo = _pcall(_rawget, debug, "info")
        if not ok or not dbginfo then
            envBad = true
        else
            if #(dbginfo(raw_getfenv, "n")) <= 1 then envBad = true end
            if #(dbginfo(print, "n")) <= 1 then envBad = true end
            if not dbginfo(print, "s") == "[C]" then envBad = true end
            if not dbginfo(require, "s") == "[C]" then envBad = true end
            if dbginfo((function() end), "s") == "[C]" then envBad = true end
            if not _select(1, _pcall(dbg_info, coroutine.wrap(function() end)(), "s")) == false then envBad = true end
        end
    end

    if envBad then
        antitamperDetect("environment sanity check failed")
    end
end

